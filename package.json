{
  "name": "lunchlineup",
  "private": true,
  "packageManager": "npm@10.8.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "postinstall": "npm run generate --workspace @lunchlineup/db",
    "test": "turbo run test",
    "test:migration": "node --test tests/deploy/*.test.mjs tests/hygiene/*.test.mjs tests/migration/*.test.mjs infrastructure/terraform/production/*.test.mjs",
    "test:integration": "node --test --test-concurrency=1 tests/integration/*.test.mjs",
    "audit:prod": "node scripts/audit-prod.mjs",
    "seed:e2e": "node scripts/seed-e2e.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "type-check": "npm run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/browser": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "ajv": "^8.18.0",
    "eslint": "^10.4.1",
    "file-type": "^21.3.1",
    "license-checker": "25.0.1",
    "postcss": "^8.5.15",
    "qs": "^6.15.3",
    "turbo": "latest",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "^16.2.7",
    "@next/swc-darwin-x64": "^16.2.7",
    "@next/swc-linux-arm64-gnu": "^16.2.7",
    "@next/swc-linux-arm64-musl": "^16.2.7",
    "@next/swc-linux-x64-gnu": "^16.2.7",
    "@next/swc-linux-x64-musl": "^16.2.7",
    "@next/swc-win32-arm64-msvc": "^16.2.7",
    "@next/swc-win32-x64-msvc": "^16.2.7"
  },
  "dependencies": {
    "pg": "8.16.3"
  }
}
