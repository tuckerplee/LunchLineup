{
  "name": "lunchlineup",
  "private": true,
  "packageManager": "npm@10.8.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:migration": "node --test tests/**/*.test.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "type-check": "npm run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/browser": "^4.1.8",
    "ajv": "^8.18.0",
    "eslint": "^10.4.1",
    "file-type": "^21.3.1",
    "postcss": "^8.5.15",
    "qs": "^6.14.2",
    "turbo": "latest",
    "vitest": "^4.1.8"
  }
}
