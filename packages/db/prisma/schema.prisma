// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-Tenant Core ───

model Tenant {
  id                         String       @id @default(uuid())
  name                       String
  slug                       String       @unique
  planTier                   PlanTier     @default(FREE)
  // Non-null Stripe identifier uniqueness is enforced by a partial SQL migration.
  stripeCustomerId           String?
  stripeSubscriptionId       String?
  stripeSubscriptionCurrentPeriodEnd DateTime?
  status                     TenantStatus @default(TRIAL)
  trialEndsAt                DateTime?
  gracePeriodEndsAt          DateTime?
  usageCredits               Int          @default(0) // Separately purchased or administratively granted credits
  creditDebt                 Int          @default(0) // Refunded or disputed purchased credits already consumed
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  deletedAt                  DateTime?
  applicationDataPurgedAt    DateTime?
  retentionLegalHoldAt       DateTime?
  retentionLegalHoldReason   String?
  retentionLegalHoldByUserId String?

  users                        User[]
  locations                    Location[]
  shifts                       Shift[]
  schedules                    Schedule[]
  scheduleSolveJobs            ScheduleSolveJob[]
  lunchBreakGenerationRequests LunchBreakGenerationRequest[]
  staffAvailabilities          StaffAvailability[]
  staffSkills                  StaffSkill[]
  scheduleDemandWindows        ScheduleDemandWindow[]
  timeCards                    TimeCard[]
  timeCardBreaks               TimeCardBreak[]
  auditLogs                    AuditLog[]
  tenantSettings               TenantSetting[]
  roles                        Role[]
  roleAssignments              RoleAssignment[]
  passwordResetTokens          PasswordResetToken[]
  passwordResetEmailOutbox     PasswordResetEmailOutbox[]
  billingEvents                BillingEvent[]
  stripeUsageEvents            StripeUsageEvent[]
  notifications                Notification[]
  webhookEndpoints             WebhookEndpoint[]
  webhookDeliveries            WebhookDelivery[]
  creditTransactions           CreditTransaction[]
  exportJobs                   TenantExportJob[]
  mfaTotpClaims                MfaTotpClaim[]
  onboardingSignupAttempts     OnboardingSignupAttempt[]
  notificationOutbox           NotificationOutbox[]
  availabilityImportJobs       AvailabilityImportJob[]
  staffInvitationOutbox        StaffInvitationOutbox[]
  deletionBillingReconciliation TenantDeletionBillingReconciliation?

  @@index([slug])
  @@index([stripeCustomerId])
  @@index([status])
}

model PlanDefinition {
  id                String   @id @default(uuid())
  code              String   @unique
  name              String
  monthlyPriceCents Int?
  locationLimit     Int?
  userLimit         Int?
  creditQuotaLimit  Int?
  active            Boolean  @default(true)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([active])
}

model CreditTransaction {
  id           String   @id @default(uuid())
  tenantId     String
  amount       Int // Wallet delta: positive for spendable grants, negative for consumed or clawed-back credits
  debtAmount   Int      @default(0) // Debt delta: positive when incurred, negative when repaid
  reason       String // E.g. "Beta signup bonus", "Schedule Generation"
  balanceAfter Int? // Immutable settlement result; legacy rows remain nullable and cannot be replayed
  debtAfter    Int? // Immutable debt result; the database fills omitted old-writer values
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
}

enum PlanTier {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum TenantStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  PURGED
}

enum TenantDeletionBillingReconciliationState {
  PENDING
  FINALIZED
}

model TenantDeletionBillingReconciliation {
  tenantId         String                                    @id
  operationId      String                                    @unique
  barrierCreatedAt DateTime
  state            TenantDeletionBillingReconciliationState @default(PENDING)
  attemptCount     Int                                       @default(0)
  nextAttemptAt    DateTime                                  @default(now())
  lastAttemptAt    DateTime?
  lastFailureAt    DateTime?
  lastErrorCode    String?
  leaseOwner       String?
  leaseToken       String?
  leaseExpiresAt   DateTime?
  finalizedAt      DateTime?
  createdAt        DateTime                                  @default(now())
  updatedAt        DateTime                                  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([state, nextAttemptAt, barrierCreatedAt, tenantId])
  @@index([leaseExpiresAt])
}

// ─── Users & Auth ───

model User {
  id                             String    @id @default(uuid())
  tenantId                       String
  email                          String?
  username                       String?
  emailEncrypted                 Bytes? // AES-256-GCM encrypted PII
  emailHash                      String? // For lookup without decryption
  name                           String
  nameEncrypted                  Bytes?
  phone                          String?
  phoneEncrypted                 Bytes?
  phoneHash                      String?
  oidcIssuer                     String?
  oidcSubject                    String?
  role                           UserRole  @default(STAFF)
  mfaEnabled                     Boolean   @default(false)
  mfaSecret                      String? // TOTP secret (encrypted)
  mfaBackupCodes                 String[] // Hashed backup codes
  passwordHash                   String?
  pinHash                        String?
  pinSetAt                       DateTime?
  pinResetRequired               Boolean   @default(false)
  pinLoginAttempts               Int       @default(0)
  pinLockedUntil                 DateTime?
  lastLoginAt                    DateTime?
  loginAttempts                  Int       @default(0)
  lockedUntil                    DateTime?
  emailDeliverySuppressedAt      DateTime?
  emailDeliverySuppressionReason String?
  emailDeliveryLastEventAt       DateTime?
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt
  suspendedAt                    DateTime?
  deletedAt                      DateTime?

  tenant                       Tenant                     @relation(fields: [tenantId], references: [id])
  sessions                     Session[]
  shifts                       Shift[]
  staffAvailabilities          StaffAvailability[]
  staffSkills                  StaffSkill[]
  timeCards                    TimeCard[]
  auditLogs                    AuditLog[]
  notifications                Notification[]
  roleAssignments              RoleAssignment[]
  passwordResetTokens          PasswordResetToken[]
  passwordResetEmailOutbox     PasswordResetEmailOutbox[]
  mfaTotpClaims                MfaTotpClaim[]
  onboardingSignupAttempts     OnboardingSignupAttempt[]
  notificationOutbox           NotificationOutbox[]
  staffInvitationOutbox        StaffInvitationOutbox[]
  requestedAvailabilityImports AvailabilityImportJob[]    @relation("AvailabilityImportRequester")
  availabilityImports          AvailabilityImportJob[]    @relation("AvailabilityImportTarget")

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@unique([tenantId, oidcIssuer, oidcSubject])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, deletedAt, createdAt, id])
  @@index([tenantId, deletedAt, suspendedAt, createdAt, id])
  @@index([username])
  @@index([emailHash])
  @@index([suspendedAt])
  @@index([deletedAt])
  @@index([emailDeliverySuppressedAt])
}

model OnboardingSignupAttempt {
  id                       String    @id @default(uuid())
  identityOrganizationHash String    @unique
  identityHash             String
  organizationHash         String
  challengeHash            String    @unique
  otpHash                  String
  otpSentAt                DateTime
  otpExpiresAt             DateTime
  otpFailedAttempts        Int       @default(0)
  verifiedAt               DateTime?
  recoveryExpiresAt        DateTime?
  tenantId                 String?   @unique
  userId                   String?   @unique
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([identityHash])
  @@index([organizationHash])
  @@index([otpExpiresAt])
  @@index([recoveryExpiresAt])
}

model Permission {
  id          String             @id @default(uuid())
  key         String             @unique
  label       String
  description String?
  category    PermissionCategory
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  rolePermissions RolePermission[]

  @@index([category])
}

model Role {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  slug        String
  description String?
  isSystem    Boolean   @default(false)
  isDefault   Boolean   @default(false)
  legacyRole  UserRole?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]
  assignments     RoleAssignment[]

  @@unique([tenantId, slug])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([legacyRole])
  @@index([deletedAt])
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model RoleAssignment {
  tenantId  String
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, roleId])
}

model TenantExportJob {
  id                            String    @id @default(uuid())
  tenantId                      String
  requestedByUserId             String
  tenantSlug                    String
  state                         String    @default("QUEUED")
  watermark                     DateTime
  expiresAt                     DateTime
  artifactKey                   String?   @unique
  bytes                         Int       @default(0)
  rowCounts                     Json?
  progressCollection            String?
  progressRows                  Int       @default(0)
  claimToken                    String?
  claimExpiresAt                DateTime?
  attempts                      Int       @default(0)
  error                         String?
  completedAt                   DateTime?
  artifactCleanupState          String    @default("NONE")
  artifactCleanupOwner          String?
  artifactCleanupLeaseExpiresAt DateTime?
  artifactCleanupAttempts       Int       @default(0)
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, requestedByUserId, createdAt])
  @@index([state, claimExpiresAt, createdAt])
  @@index([expiresAt, state])
  @@index([artifactCleanupState, artifactCleanupLeaseExpiresAt, updatedAt], map: "TenantExportJob_artifact_cleanup_idx")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
}

enum PermissionCategory {
  AUTH
  ADMIN
  USERS
  LOCATIONS
  SHIFTS
  SCHEDULES
  LUNCH_BREAKS
  TIME_CARDS
  PAYROLL
  NOTIFICATIONS
  BILLING
  SETTINGS
}

model Session {
  id           String    @id @default(uuid())
  userId       String
  selectorHash String?   @unique // Hash of the stable opaque cookie selector; null for legacy sessions
  refreshToken String    @unique // SHA-256 hash of the rotating refresh validator
  ipAddress    String
  userAgent    String
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  user                User                 @relation(fields: [userId], references: [id])
  refreshTokenReplays RefreshTokenReplay[]

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@index([revokedAt])
}

model RefreshTokenReplay {
  id            String   @id @default(uuid())
  sessionId     String
  validatorHash String   @unique
  createdAt     DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model MfaTotpClaim {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  timeStep  BigInt
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, timeStep])
  @@index([tenantId, userId, createdAt])
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  tenantId   String
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([expiresAt])
  @@index([tenantId, userId, consumedAt])
}

enum PasswordResetEmailStatus {
  PENDING
  SENDING
  FAILED
  DELIVERED
  DEAD_LETTERED
}

enum StaffInvitationOutboxStatus {
  PENDING
  SENDING
  FAILED
  DELIVERED
  DEAD_LETTERED
  CANCELLED
}

enum StaffInvitationPurpose {
  STAFF_INVITATION
}

model StaffInvitationOutbox {
  id                    String                      @id @default(uuid())
  tenantId              String
  userId                String
  recipientHash         String
  purpose               StaffInvitationPurpose      @default(STAFF_INVITATION)
  encryptedPayload      Bytes?
  encryptionNonce       Bytes?
  encryptionTag         Bytes?
  encryptionKeyRef      String?
  payloadVersion        Int                         @default(1)
  status                StaffInvitationOutboxStatus @default(PENDING)
  attempts              Int                         @default(0)
  manualRetryCount      Int                         @default(0)
  retryAt               DateTime?                   @default(now())
  leaseOwner            String?
  leaseExpiresAt        DateTime?
  providerMessageId     String?
  lastErrorCode         String?
  deliveredAt           DateTime?
  deadLetteredAt        DateTime?
  cancelledAt           DateTime?
  payloadErasedAt       DateTime?
  diagnosticsEraseAfter DateTime?
  diagnosticsErasedAt   DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [tenantId, userId], references: [tenantId, id], onDelete: Cascade)

  @@unique([tenantId, userId, purpose])
  @@index([status, retryAt, createdAt])
  @@index([status, leaseExpiresAt])
  @@index([tenantId, status, retryAt])
  @@index([tenantId, userId])
  @@index([status, diagnosticsEraseAfter, id])
}

model PasswordResetEmailOutbox {
  id               String                   @id @default(uuid())
  tenantId         String
  userId           String
  tokenHash        String                   @unique
  encryptedPayload String
  encryptionKeyRef String
  status           PasswordResetEmailStatus @default(PENDING)
  attempts         Int                      @default(0)
  nextAttemptAt    DateTime                 @default(now())
  leaseUntil       DateTime?
  expiresAt        DateTime
  deliveredAt      DateTime?
  deadLetteredAt   DateTime?
  lastError        String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([leaseUntil])
  @@index([tenantId, userId])
  @@index([expiresAt])
}

// ─── Locations & Scheduling ───

model Location {
  id                     String    @id @default(uuid())
  tenantId               String
  name                   String
  address                String?
  timezone               String
  creationRequestKeyHash String?
  creationRequestHash    String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  shifts                Shift[]
  schedules             Schedule[]
  scheduleSolveJobs     ScheduleSolveJob[]
  staffAvailabilities   StaffAvailability[]
  scheduleDemandWindows ScheduleDemandWindow[]
  timeCards             TimeCard[]

  @@unique([tenantId, creationRequestKeyHash])
  @@index([tenantId])
  @@index([tenantId, deletedAt, name, id])
  @@index([deletedAt])
}

model Schedule {
  id          String         @id @default(uuid())
  tenantId    String
  locationId  String
  startDate   DateTime
  endDate     DateTime
  status      ScheduleStatus @default(DRAFT)
  publishedAt DateTime?
  revision    Int            @default(0)
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant        Tenant                 @relation(fields: [tenantId], references: [id])
  location      Location               @relation(fields: [locationId], references: [id])
  shifts        Shift[]
  solveJobs     ScheduleSolveJob[]
  demandWindows ScheduleDemandWindow[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, deletedAt, startDate(sort: Desc), id(sort: Desc)])
  @@index([locationId])
  @@index([startDate, endDate])
  @@index([tenantId, locationId, startDate, endDate])
}

model ScheduleSolveJob {
  id                   String    @id
  tenantId             String
  scheduleId           String
  locationId           String
  requestKeyHash       String
  requestHash          String
  status               String    @default("QUEUED")
  statusReason         String?
  retryCount           Int       @default(0)
  resultShiftCount     Int?
  requestedConstraints Json?
  staffSnapshot        Json?
  demandSnapshot       Json?
  creditConsumption    Json?
  queuePayload         Json?
  publicationStatus    String    @default("PENDING")
  publishAttempts      Int       @default(0)
  nextPublishAt        DateTime  @default(now())
  publishLeaseUntil    DateTime?
  publishedAt          DateTime?
  publishLastError     String?
  executionToken       String?
  executionLeaseUntil  DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  schedule Schedule @relation(fields: [scheduleId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([tenantId, scheduleId, requestKeyHash])
  @@index([tenantId])
  @@index([scheduleId])
  @@index([locationId])
  @@index([tenantId, scheduleId, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([publicationStatus, nextPublishAt, createdAt])
  @@index([publishLeaseUntil])
  @@index([executionLeaseUntil])
}

model LunchBreakGenerationRequest {
  id                  String    @id @default(uuid())
  tenantId            String
  requestKeyHash      String
  requestHash         String
  status              String    @default("PENDING")
  creditConsumption   Json?
  response            Json?
  failureStatus       Int?
  failureMessage      String?
  claimToken          String?
  claimExpiresAt      DateTime?
  attempts            Int       @default(0)
  creditTransactionId String?
  calculationSnapshot Json?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, requestKeyHash])
  @@index([tenantId, status, createdAt])
  @@index([status, claimExpiresAt])
}

model StaffAvailability {
  id               String   @id @default(uuid())
  tenantId         String
  userId           String
  locationId       String?
  dayOfWeek        Int
  startTimeMinutes Int
  endTimeMinutes   Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([locationId])
  @@index([tenantId, userId, dayOfWeek, startTimeMinutes])
  @@index([tenantId, locationId, dayOfWeek, startTimeMinutes])
}

enum AvailabilityImportStatus {
  PENDING
  QUEUED
  RUNNING
  RETRYING
  SUCCEEDED
  FAILED
  DEAD_LETTERED
  CANCELLED
}

enum AvailabilityImportPublicationStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
}

model AvailabilityImportJob {
  id                     String                              @id
  tenantId               String
  userId                 String
  requestedByUserId      String?
  requestKeyHash         String
  requestHash            String
  targetIdentityHash     String
  status                 AvailabilityImportStatus            @default(PENDING)
  publicationStatus      AvailabilityImportPublicationStatus @default(PENDING)
  publishToken           String?
  publishLeaseUntil      DateTime?
  publishAttempts        Int                                 @default(0)
  nextPublishAt          DateTime                            @default(now())
  publicationAmbiguous   Boolean                             @default(false)
  publishLastError       String?
  publishedAt            DateTime?
  storageKey             String?
  encryptedSourcePayload Bytes?
  fileSha256             String
  fileSize               Int
  parsedAvailability     Json?
  resultErasedAt         DateTime?
  failureCode            String?
  creditConsumption      Json?
  attempts               Int                                 @default(0)
  executionToken         String?
  executionLeaseUntil    DateTime?
  queuedAt               DateTime?
  startedAt              DateTime?
  completedAt            DateTime?
  expiresAt              DateTime
  createdAt              DateTime                            @default(now())
  updatedAt              DateTime                            @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User   @relation("AvailabilityImportTarget", fields: [userId], references: [id], onDelete: Cascade)
  requestedBy User?  @relation("AvailabilityImportRequester", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, requestKeyHash])
  @@index([tenantId, userId, createdAt(sort: Desc)])
  @@index([tenantId, status, createdAt])
  @@index([publicationStatus, nextPublishAt, createdAt])
  @@index([publishLeaseUntil])
  @@index([status, executionLeaseUntil])
  @@index([status, completedAt])
  @@index([expiresAt])
}

model StaffSkill {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  skill     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId, skill])
  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, skill])
}

model ScheduleDemandWindow {
  id            String   @id @default(uuid())
  tenantId      String
  scheduleId    String
  locationId    String
  startTime     DateTime
  endTime       DateTime
  requiredStaff Int      @default(1)
  skill         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  schedule Schedule @relation(fields: [scheduleId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@index([tenantId])
  @@index([scheduleId])
  @@index([locationId])
  @@index([tenantId, scheduleId, startTime])
  @@index([tenantId, locationId, startTime])
}

enum ScheduleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Shift {
  id         String    @id @default(uuid())
  tenantId   String
  locationId String
  scheduleId String?
  userId     String?
  startTime  DateTime
  endTime    DateTime
  role       String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  location  Location   @relation(fields: [locationId], references: [id])
  schedule  Schedule?  @relation(fields: [scheduleId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])
  breaks    Break[]
  timeCards TimeCard[]

  @@index([tenantId])
  @@index([locationId])
  @@index([scheduleId])
  @@index([userId])
  @@index([startTime, endTime])
  @@index([deletedAt])
  @@index([tenantId, deletedAt, startTime, id])
  @@index([tenantId, locationId, deletedAt, startTime])
  @@index([tenantId, scheduleId, deletedAt, startTime])
  @@index([tenantId, userId, deletedAt, startTime])
}

model Break {
  id        String     @id @default(uuid())
  shiftId   String
  type      BreakType?
  startTime DateTime
  endTime   DateTime
  paid      Boolean    @default(false)
  createdAt DateTime   @default(now())

  shift Shift @relation(fields: [shiftId], references: [id])

  @@index([shiftId])
  @@index([type])
}

// ─── Platform Configuration (Part I-A) ───

enum BreakType {
  BREAK1
  LUNCH
  BREAK2
}

model TimeCard {
  id                 String         @id @default(uuid())
  tenantId           String
  userId             String
  locationId         String?
  shiftId            String?
  clockInOperationId String?        @unique
  clockInRequestHash String?
  clockInAt          DateTime
  clockOutAt         DateTime?
  payrollPeriodId    String?
  workTimeZone       String         @default("UTC")
  revision           Int            @default(1)
  breakMinutes       Int            @default(0)
  notes              String?
  status             TimeCardStatus @default(OPEN)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  user     User            @relation(fields: [userId], references: [id])
  location Location?       @relation(fields: [locationId], references: [id])
  shift    Shift?          @relation(fields: [shiftId], references: [id])
  breaks   TimeCardBreak[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@index([locationId])
  @@index([shiftId])
  @@index([clockInAt])
  @@index([status])
  @@index([deletedAt])
  @@index([tenantId, deletedAt, clockInAt(sort: Desc), id(sort: Desc)])
  @@index([tenantId, userId, deletedAt, clockInAt(sort: Desc), id(sort: Desc)])
  @@index([tenantId, userId, status, deletedAt, clockInAt])
  @@index([tenantId, locationId, deletedAt, clockInAt])
  @@index([tenantId, payrollPeriodId, status, deletedAt, id])
}

model TimeCardBreak {
  id         String   @id @default(uuid())
  tenantId   String
  timeCardId String
  startAt    DateTime
  endAt      DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  timeCard TimeCard @relation(fields: [timeCardId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([timeCardId, startAt])
  @@index([tenantId, timeCardId])
}

model PayrollPolicyVersion {
  id              String         @id @default(uuid())
  tenantId        String
  version         Int
  timeZone        String
  cadence         PayrollCadence
  anchorDate      DateTime       @db.Date
  effectiveFrom   DateTime       @db.Date
  operationId     String         @unique
  requestHash     String
  createdByUserId String
  createdAt       DateTime       @default(now())

  @@unique([id, tenantId])
  @@unique([tenantId, version])
  @@unique([tenantId, effectiveFrom])
  @@index([tenantId, effectiveFrom(sort: Desc), version(sort: Desc)])
}

model PayrollPeriod {
  id                    String              @id @default(uuid())
  tenantId              String
  policyVersionId       String
  localStartDate        DateTime            @db.Date
  localEndDateExclusive DateTime            @db.Date
  startsAt              DateTime
  endsAt                DateTime
  timeZone              String
  cadence               PayrollCadence
  status                PayrollPeriodStatus @default(OPEN)
  revision              Int                 @default(0)
  reviewStartedAt       DateTime?
  reviewStartedByUserId String?
  lockedAt              DateTime?
  lockedByUserId        String?
  lockOperationId       String?             @unique
  lockRequestHash       String?
  lockedEntrySha256     String?
  lockedEntryCount      Int?
  totalPayableMinutes   Int?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([tenantId, localStartDate])
  @@unique([id, tenantId])
  @@index([tenantId, startsAt, endsAt])
  @@index([tenantId, status, localStartDate(sort: Desc), id(sort: Desc)])
}

model PayrollTimeCardApproval {
  id               String                  @id @default(uuid())
  tenantId         String
  periodId         String
  timeCardId       String
  timeCardRevision Int
  decision         PayrollApprovalDecision
  reason           String?
  operationId      String                  @unique
  requestHash      String
  decidedAt        DateTime                @default(now())
  decidedByUserId  String

  @@unique([tenantId, timeCardId, timeCardRevision])
  @@index([tenantId, periodId, decision, timeCardId])
}

model PayrollLockedEntry {
  id               String            @id @default(uuid())
  tenantId         String
  periodId         String
  sequence         Int
  sourceType       PayrollSourceType
  sourceId         String
  sourceRevision   Int
  employeeId       String
  locationId       String?
  workTimeZone     String
  clockInAt        DateTime
  clockOutAt       DateTime
  breakMinutes     Int
  payableMinutes   Int
  approvedAt       DateTime
  approvedByUserId String
  canonicalSha256  String
  createdAt        DateTime          @default(now())

  @@unique([id, tenantId])
  @@unique([periodId, sequence])
  @@unique([periodId, sourceType, sourceId])
  @@index([tenantId, periodId, employeeId, sequence])
}

model PayrollAmendment {
  id                        String   @id @default(uuid())
  tenantId                  String
  lockedEntryId             String
  adjustmentPeriodId        String
  operationId               String   @unique
  requestHash               String
  requestedByUserId         String
  reason                    String
  replacementClockInAt      DateTime
  replacementClockOutAt     DateTime
  replacementBreakMinutes   Int
  replacementPayableMinutes Int
  minuteDelta               Int
  createdAt                 DateTime @default(now())

  @@unique([id, tenantId])
  @@index([tenantId, adjustmentPeriodId, createdAt, id])
  @@index([tenantId, lockedEntryId])
}

model PayrollAmendmentDecision {
  id              String                  @id @default(uuid())
  tenantId        String
  amendmentId     String                  @unique
  decision        PayrollApprovalDecision
  reason          String?
  operationId     String                  @unique
  requestHash     String
  decidedByUserId String
  decidedAt       DateTime                @default(now())

  @@index([tenantId, decision, decidedAt, id])
}

model PayrollOperation {
  operationId String               @id
  tenantId    String
  periodId    String?
  kind        PayrollOperationKind
  requestHash String
  response    Json
  createdAt   DateTime             @default(now())

  @@index([tenantId, periodId, kind])
}

model PayrollExportBatch {
  id                  String              @id @default(uuid())
  tenantId            String
  periodId            String              @unique
  operationId         String              @unique
  requestHash         String
  creditTransactionId String              @unique
  formatVersion       Int                 @default(1)
  status              PayrollExportStatus @default(GENERATED)
  contentSha256       String
  rowCount            Int
  totalPayableMinutes Int
  consumedCredits     Int
  newBalance          Int
  createdAt           DateTime            @default(now())
  downloadedAt        DateTime?
  reconciledAt        DateTime?
  updatedAt           DateTime            @updatedAt

  @@unique([id, tenantId])
  @@index([tenantId, status, createdAt(sort: Desc), id(sort: Desc)])
}

model PayrollExportLine {
  id              String            @id @default(uuid())
  tenantId        String
  batchId         String
  lineNumber      Int
  lockedEntryId   String
  sourceType      PayrollSourceType
  sourceId        String
  employeeId      String
  locationId      String?
  workTimeZone    String
  clockInAt       DateTime
  clockOutAt      DateTime
  breakMinutes    Int
  payableMinutes  Int
  canonicalSha256 String
  createdAt       DateTime          @default(now())

  @@unique([id, tenantId])
  @@unique([batchId, lineNumber])
  @@unique([batchId, lockedEntryId])
  @@index([tenantId, batchId, lineNumber])
}

model PayrollReconciliationReceipt {
  id                   String   @id @default(uuid())
  tenantId             String
  batchId              String
  provider             String
  providerEventId      String
  payloadSha256        String
  providerTotalMinutes Int
  acceptedCount        Int
  rejectedCount        Int
  pendingCount         Int
  receivedByUserId     String
  receivedAt           DateTime @default(now())

  @@unique([id, tenantId])
  @@unique([tenantId, provider, providerEventId])
  @@index([tenantId, batchId, receivedAt, id])
}

model PayrollReconciliationLineEvent {
  id        String                          @id @default(uuid())
  tenantId  String
  receiptId String
  batchId   String
  lineId    String
  status    PayrollReconciliationLineStatus
  reason    String?
  createdAt DateTime                        @default(now())

  @@unique([receiptId, lineId])
  @@index([tenantId, batchId, lineId, createdAt])
}

model PayrollReconciliationLineState {
  id              String                          @id @default(uuid())
  tenantId        String
  batchId         String
  lineId          String
  status          PayrollReconciliationLineStatus
  latestReceiptId String
  reason          String?
  updatedAt       DateTime                        @updatedAt

  @@unique([batchId, lineId])
  @@index([tenantId, batchId, status, lineId])
}

enum TimeCardStatus {
  OPEN
  CLOSED
  VOID
}

enum PayrollCadence {
  WEEKLY
  BIWEEKLY
}

enum PayrollPeriodStatus {
  OPEN
  REVIEW
  LOCKED
}

enum PayrollOperationKind {
  POLICY_CREATE
  PERIOD_CREATE
  ADOPT
  REVIEW
  APPROVAL
  LOCK
  AMENDMENT_CREATE
  AMENDMENT_DECISION
  EXPORT
  RECONCILE
}

enum PayrollExportStatus {
  GENERATED
  DOWNLOADED
  RECONCILING
  RECONCILED
}

enum PayrollApprovalDecision {
  APPROVED
  REJECTED
}

enum PayrollSourceType {
  TIME_CARD
  AMENDMENT
}

enum PayrollReconciliationLineStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model PlatformConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
}

model TenantSetting {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@index([tenantId])
}

// ─── Billing (Part XII) ───

model BillingEvent {
  id            String   @id @default(uuid())
  tenantId      String
  type          String // invoice.paid, subscription.created, etc.
  stripeEventId String?  @unique
  amount        Int? // cents
  currency      String?  @default("usd")
  metadata      Json?
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@index([createdAt])
}

enum StripeUsageMetric {
  ACTIVE_STAFF
}

enum StripeUsageEventStatus {
  PENDING
  SENDING
  SENT
  FAILED
  DEAD_LETTERED
}

model StripeUsageEvent {
  id               String                 @id @default(uuid())
  tenantId         String
  metric           StripeUsageMetric
  periodStart      DateTime
  periodEnd        DateTime
  quantity         Int
  eventName        String
  stripeCustomerId String
  identifier       String                 @unique
  idempotencyKey   String                 @unique
  status           StripeUsageEventStatus @default(PENDING)
  attempts         Int                    @default(0)
  nextAttemptAt    DateTime               @default(now())
  submittedAt      DateTime?
  sentAt           DateTime?
  stripeObjectId   String?
  stripeRequestId  String?
  lastError        String?
  metadata         Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, metric, periodStart, periodEnd])
  @@index([tenantId])
  @@index([status, nextAttemptAt])
  @@index([eventName, status, submittedAt])
}

// ─── Audit Log (Append-Only, Part VII) ───

model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String
  userId        String?
  actorUserId   String?
  actorTenantId String?
  action        String
  resource      String
  resourceId    String?
  oldValue      Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  // BRIN index for time-series queries on this high-churn table
  @@index([tenantId])
  @@index([createdAt])
  @@index([action])
  @@index([resource, resourceId])
  @@index([tenantId, createdAt])
  @@index([actorTenantId, actorUserId])
}

// ─── Notifications ───

model Notification {
  id        String           @id @default(uuid())
  tenantId  String
  userId    String
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@index([tenantId])
  @@index([createdAt])
}

enum NotificationOutboxStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  DEAD_LETTERED
}

model NotificationOutbox {
  id               String                   @id @default(uuid())
  tenantId         String
  userId           String
  dedupeKey        String
  notificationType NotificationType
  title            String
  body             String
  status           NotificationOutboxStatus @default(PENDING)
  attempts         Int                      @default(0)
  nextAttemptAt    DateTime?                @default(now())
  leaseUntil       DateTime?
  deliveredAt      DateTime?
  lastError        String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dedupeKey])
  @@index([status, nextAttemptAt])
  @@index([status, leaseUntil])
  @@index([tenantId, status, nextAttemptAt])
  @@index([tenantId, userId])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  SCHEDULE_PUBLISHED
  SHIFT_ASSIGNED
  SHIFT_CHANGED
}

// ─── Webhooks ───

model WebhookEndpoint {
  id        String   @id @default(uuid())
  tenantId  String
  url       String
  secret    String // AES-256-GCM envelope containing the HMAC signing secret
  events    String[] // Which event types to deliver
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([active])
}

enum WebhookDeliveryStatus {
  PENDING
  QUEUED
  SENDING
  DELIVERED
  FAILED
  DEAD_LETTERED
}

model WebhookDelivery {
  id               String                @id @default(uuid())
  tenantId         String
  endpointId       String?
  status           WebhookDeliveryStatus @default(PENDING)
  eventType        String?
  endpointRef      String
  payloadDigest    String
  payloadBytes     Int
  encryptedUrl     String
  encryptedPayload String
  encryptionKeyRef String
  attempts         Int                   @default(0)
  nextAttemptAt    DateTime?             @default(now())
  queuedAt         DateTime?
  deliveredAt      DateTime?
  lastError        String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([endpointId])
  @@index([status, nextAttemptAt])
  @@index([status, updatedAt])
  @@index([tenantId, status, nextAttemptAt])
  @@index([payloadDigest])
}
