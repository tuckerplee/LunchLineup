# ─── Core ───
NODE_ENV=development
PORT=3000

# ─── Domain & TLS ───
DOMAIN=localhost
ADMIN_EMAIL=admin@example.com

# ─── Database ───
DATABASE_URL=postgresql://root:password@localhost:5432/lunchlineup
POSTGRES_USER=root
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=lunchlineup

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── RabbitMQ ───
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ─── Auth / OIDC ───
OIDC_ISSUER_URL=https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback

# ─── JWT & Sessions ───
JWT_SECRET=generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=generate_with_openssl_rand_hex_64
SESSION_SECRET=generate_with_openssl_rand_hex_64

# ─── CSRF ───
CSRF_SECRET=generate_with_openssl_rand_hex_32

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── Observability ───
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ─── Control Plane ───
CONTROL_PLANE_PORT=3001
CONTROL_PLANE_USER=admin
CONTROL_PLANE_PASSWORD=change_me

# ─── WebSocket ───
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
