# Core
NODE_ENV=development
DATA_TARGET_ENV=development
MIGRATION_PRODUCTION_CONFIRM=
PORT=3000

# Domain, TLS, and proxy routing
# Production must set DOMAIN/CADDY_SITE_ADDRESSES to public HTTPS hostnames.
# Add internal scrape/health hosts such as api:3000 or 127.0.0.1:3000 to ALLOWED_HOSTS only when needed.
DOMAIN=localhost
PRODUCTION_API_HEALTH_URL=
ADMIN_EMAIL=admin@example.com
CADDY_SITE_ADDRESSES=http://localhost:80, http://127.0.0.1:80, http://proxy:80
PROXY_HTTP_BIND=127.0.0.1
PROXY_HTTPS_BIND=127.0.0.1
API_HOST_BIND=127.0.0.1
API_HOST_PORT=4000
API_INTERNAL_HOSTS=api,api:3000
ALLOWED_HOSTS=localhost,localhost:80,localhost:4000,127.0.0.1,127.0.0.1:80,127.0.0.1:4000
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1

# Database
# POSTGRES_* initializes the database owner used only by migrations, backup, and recovery.
# APP_DB_* is the restricted login used by API/runtime services so PostgreSQL RLS applies.
# Public Compose launches must use postgres:5432/POSTGRES_DB; bundled logical backup and PITR protect that authoritative service.
POSTGRES_USER=lunchlineup_admin
POSTGRES_PASSWORD=
POSTGRES_DB=lunchlineup
APP_DB_USER=lunchlineup_app
APP_DB_PASSWORD=
PLATFORM_ADMIN_DB_CONTEXT_SECRET=
DATABASE_URL=
MIGRATION_DATABASE_URL=
# Deployment tooling supplies the candidate SHA and authenticated current-release
# baseline. Set the fresh confirmation only for a proven empty production database.
MIGRATION_SOURCE_SHA=
MIGRATION_BASELINE_SOURCE_SHA=
MIGRATION_FRESH_DATABASE_CONFIRM=

# Production PostgreSQL point-in-time recovery. Development may leave disabled.
# Use a unique immutable cluster prefix; never share it between primaries.
PITR_ENABLED=false
PITR_S3_ENDPOINT=https://s3.example.com
PITR_S3_BUCKET=
PITR_S3_PREFIX=lunchlineup/production/replace-with-cluster-id
PITR_WAL_OBJECT_STORE_SECRETS_DIR=./secrets/pitr-wal-object-store
PITR_BASE_BACKUP_OBJECT_STORE_SECRETS_DIR=./secrets/pitr-base-backup-object-store
PITR_RESTORE_OBJECT_STORE_SECRETS_DIR=./secrets/pitr-restore-object-store
PITR_LIFECYCLE_AUDIT_OBJECT_STORE_SECRETS_DIR=./secrets/pitr-lifecycle-audit-object-store
PITR_OBJECT_LOCK_RETENTION_DAYS=14
PITR_LIFECYCLE_MAX_RETENTION_DAYS=35
PITR_LIFECYCLE_POLICY_PROOF_FILE=./secrets/pitr-lifecycle-policy.json
PITR_LIFECYCLE_POLICY_PROOF_URI=s3://lunchlineup-prod/pitr-policy/lifecycle-policy-YYYYMMDD.json
PITR_LIFECYCLE_POLICY_SHA256=
BACKUP_ENCRYPTION_KEY_SECRET_FILE=./secrets/backup_key

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=
PROCESS_SHUTDOWN_DEADLINE_MS=30000
RABBITMQ_USER=lunchlineup
RABBITMQ_PASSWORD=
SCHEDULE_OUTBOX_MAX_PUBLISH_ATTEMPTS=8
SCHEDULE_OUTBOX_MAX_PUBLICATION_AGE_MS=86400000

# Auth / OIDC
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback
# Safe default for every environment. Local development may explicitly opt into
# invite_only or open to exercise those flows. Production is code-locked to
# closed_beta until counsel approves versioned self-service Terms and a future
# code change updates the legal gate.
PUBLIC_SIGNUP_MODE=closed_beta
NEXT_PUBLIC_SIGNUP_MODE=closed_beta
PUBLIC_SIGNUP_INVITE_CODES=
ADMIN_TENANT_TRIAL_DAYS=14
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# JWT, sessions, and CSRF
JWT_SECRET=
JWT_REFRESH_SECRET=
OTP_HMAC_SECRET=
SESSION_SECRET=
# 32-byte hex/base64 managed keys. During migration, CURRENT writes enc:v2 values,
# PREVIOUS reads the former managed key, and the deprecated legacy key reads enc:v1 values only.
MFA_SECRET_ENCRYPTION_KEY_CURRENT=
MFA_SECRET_ENCRYPTION_KEY_PREVIOUS=
MFA_SECRET_ENCRYPTION_KEY=
# 32-byte hex/base64 managed key. During rotation, set PREVIOUS to the former CURRENT value.
WEBHOOK_DELIVERY_ENCRYPTION_KEY_CURRENT=
WEBHOOK_DELIVERY_ENCRYPTION_KEY_PREVIOUS=
# Dedicated exact 32-byte hex/base64 delivery keys; never reuse key material across outboxes.
# Enable staff invitation delivery in every production API and worker process.
PASSWORD_RESET_OUTBOX_ENCRYPTION_KEY=
STAFF_INVITATION_OUTBOX_ENABLED=false
STAFF_INVITATION_MAX_ATTEMPTS=8
STAFF_INVITATION_LEASE_SECONDS=120
STAFF_INVITATION_SWEEP_INTERVAL_SECONDS=10
STAFF_INVITATION_SWEEP_BATCH_SIZE=25
STAFF_INVITATION_PROVIDER_TIMEOUT_SECONDS=10
STAFF_INVITATION_RETRY_BASE_SECONDS=15
STAFF_INVITATION_RETRY_MAX_SECONDS=3600
STAFF_INVITATION_RETRY_JITTER_RATIO=0.25
STAFF_INVITATION_PROVIDER_FAILURE_THRESHOLD=3
STAFF_INVITATION_PROVIDER_HEALTH_WINDOW_SECONDS=300
STAFF_INVITATION_DIAGNOSTICS_COUNT_CAP=1000
STAFF_INVITATION_SWEEP_MAX_STALENESS_SECONDS=60
STAFF_INVITATION_OUTBOX_ENCRYPTION_KEY=
AVAILABILITY_IMPORT_ENCRYPTION_KEY=
COOKIE_SECURE=false
CSRF_SECRET=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=
PASSWORD_RESET_EMAIL_OUTBOX_ENABLED=true
PASSWORD_RESET_EMAIL_MAX_ATTEMPTS=5
PASSWORD_RESET_EMAIL_SWEEP_INTERVAL_SECONDS=10
PASSWORD_RESET_EMAIL_SWEEP_BATCH_SIZE=25

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_ENDPOINT_ID=
STRIPE_METER_ERROR_WEBHOOK_SECRET=
STRIPE_METER_ERROR_EVENT_DESTINATION_ID=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_CREDIT_PACK_100=
STRIPE_PRICE_CREDIT_PACK_500=
STRIPE_PRICE_CREDIT_PACK_2000=
STRIPE_METER_ID=
STRIPE_METER_AGGREGATION=last
STRIPE_METERED_USAGE_ENABLED=false
STRIPE_METER_EVENT_NAME=
STRIPE_USAGE_SNAPSHOT_INTERVAL_SECONDS=300
STRIPE_USAGE_SWEEP_BATCH_SIZE=100
STRIPE_USAGE_DEAD_LETTER_REPLAY_ENABLED=false
STRIPE_USAGE_DEAD_LETTER_REPLAY_BATCH_SIZE=25
STRIPE_USAGE_DEAD_LETTER_REPLAY_MIN_AGE_SECONDS=900
STRIPE_USAGE_DEAD_LETTER_MAX_REPLAYS=1

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
METRICS_TOKEN_FILE=./secrets/metrics_token
RETENTION_PURGE_SERVICE_TOKEN_SECRET_FILE=./secrets/retention_purge_token
ALERTMANAGER_WEBHOOK_URL_FILE=./secrets/alertmanager_webhook_url
API_REPLICA_COUNT=1
# Compose mounts this absolute container path from the shared tenant_export_artifacts volume.
TENANT_EXPORT_ARTIFACT_DIRECTORY=/var/lib/lunchlineup/tenant-exports
TENANT_EXPORT_SHARED_STORAGE=true
GRAFANA_USER=lunchlineup_admin
GRAFANA_PASSWORD=

# Control Plane
CONTROL_PLANE_HOST=127.0.0.1
CONTROL_PLANE_PORT=3001
CONTROL_PLANE_ADMIN_TOKEN_SECRET_FILE=./secrets/control_plane_admin_token
CONTROL_PLANE_ADMIN_TOKEN_FILE=./secrets/control_plane_admin_token
CONTROL_PLANE_METRICS_TOKEN_FILE=./secrets/metrics_token
CONTROL_PLANE_USER=admin
CONTROL_PLANE_PASSWORD=

# Frontend
# Required in production by Compose and API startup. Use the browser-visible,
# public HTTPS origin with no path, query, or fragment.
APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
# Production launch validation requires same-origin /api/v1; set INTERNAL_API_URL
# to choose the server-side proxy target.
NEXT_PUBLIC_API_URL=/api/v1
INTERNAL_API_URL=http://api:3000/v1
LUNCHLINEUP_STATUS_HEALTH_URL=
NEXT_PUBLIC_OIDC_ENABLED=false

# Public legal and support contacts
# Production must replace .example placeholders with monitored addresses.
NEXT_PUBLIC_PRIVACY_CONTACT_EMAIL=privacy@lunchlineup.example
NEXT_PUBLIC_SUPPORT_CONTACT_EMAIL=support@lunchlineup.example
NEXT_PUBLIC_DPA_CONTACT_EMAIL=privacy@lunchlineup.example

# Paid GA legal approval gate. Production validation rejects placeholders and
# requires a retained approval record; never set these values without counsel.
PAID_GA_LEGAL_APPROVED=false
PAID_GA_CONTRACTING_ENTITY=
PAID_GA_TERMS_VERSION=
PAID_GA_DPA_VERSION=
PAID_GA_COUNSEL_APPROVAL_OWNER=
PAID_GA_COUNSEL_APPROVED_AT=
PAID_GA_INCIDENT_NOTICE_HOURS=
PAID_GA_SIGNATURE_PROCESS=
PAID_GA_TRANSFER_TERMS=
PAID_GA_CONTACT_OWNER_EMAIL=
PAID_GA_APPROVAL_RECORD_URI=
