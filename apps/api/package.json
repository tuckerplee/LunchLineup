{
    "name": "@lunchlineup/api",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "build": "nest build -p tsconfig.build.json",
        "format": "prettier --write \"src/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "start:webhook-replay": "node dist/webhooks/webhook-replay.worker.js",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
        "typecheck": "tsc --noEmit --rootDir ../.. --incremental false",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:cov": "vitest run --coverage",
        "test:debug": "vitest run --reporter=verbose",
        "test:e2e": "vitest run --project=e2e"
    },
    "dependencies": {
        "@lunchlineup/config": "*",
        "@lunchlineup/db": "*",
        "@lunchlineup/rbac": "*",
        "@nestjs/common": "^11.1.24",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.24",
        "@nestjs/platform-express": "^11.1.24",
        "@nestjs/throttler": "^6.5.0",
        "@opentelemetry/api": "1.9.1",
        "@opentelemetry/auto-instrumentations-node": "0.78.0",
        "@opentelemetry/exporter-trace-otlp-proto": "0.220.0",
        "@opentelemetry/resources": "2.9.0",
        "@opentelemetry/sdk-node": "0.220.0",
        "@prisma/client": "^5.22.0",
        "@types/amqplib": "^0.10.8",
        "amqplib": "^0.10.9",
        "axios": "^1.13.6",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.6",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "^9.0.3",
        "reflect-metadata": "^0.2.0",
        "resend": "^6.9.3",
        "rxjs": "^7.8.1",
        "stripe": "^20.4.0",
        "winston": "^3.19.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.21",
        "@nestjs/schematics": "^11.1.0",
        "@nestjs/testing": "^11.1.24",
        "@types/cookie-parser": "^1.4.7",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.2",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^26.1.1",
        "@types/supertest": "^6.0.0",
        "@vitest/coverage-v8": "^4.1.8",
        "jest": "^29.5.0",
        "prom-client": "^15.1.3",
        "ts-jest": "^29.1.0",
        "ts-loader": "^9.4.3",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.1.3",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^4.1.8"
    }
}
