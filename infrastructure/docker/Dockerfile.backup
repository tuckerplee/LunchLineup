# infrastructure/docker/Dockerfile.backup
# Pinned provider client used by the request-scoped WAL uploader.
FROM minio/mc:RELEASE.2025-08-13T08-35-41Z@sha256:a7fe349ef4bd8521fb8497f55c6042871b2ae640607cf99d9bede5e9bdf11727 AS pitr-client

# Stage 2: Runtime
FROM alpine:3.24@sha256:28bd5fe8b56d1bd048e5babf5b10710ebe0bae67db86916198a6eec434943f8b AS runner
RUN apk add --no-cache postgresql-client rsync zstd gpg aws-cli rclone nodejs coreutils \
  && if ! grep -q '^postgres:' /etc/group; then addgroup -S -g 70 postgres; fi \
  && if ! grep -q '^postgres:' /etc/passwd; then adduser -S -D -H -u 70 -G postgres postgres; fi
WORKDIR /app
COPY scripts/backup.sh .
COPY scripts/pitr-wal-provider.mjs .
COPY infrastructure/postgres/pitr-object-store.sh /opt/lunchlineup/infrastructure/postgres/pitr-object-store.sh
COPY infrastructure/postgres/pitr-export-lifecycle-policy.sh /opt/lunchlineup/infrastructure/postgres/pitr-export-lifecycle-policy.sh
COPY infrastructure/postgres/pitr-verify-object-store.sh /opt/lunchlineup/infrastructure/postgres/pitr-verify-object-store.sh
COPY infrastructure/postgres/pitr-wal-provider-upload.sh /opt/lunchlineup/infrastructure/postgres/pitr-wal-provider-upload.sh
COPY --from=pitr-client /usr/bin/mc /opt/lunchlineup/tools/mc
RUN chmod +x \
  backup.sh \
  /opt/lunchlineup/infrastructure/postgres/pitr-object-store.sh \
  /opt/lunchlineup/infrastructure/postgres/pitr-export-lifecycle-policy.sh \
  /opt/lunchlineup/infrastructure/postgres/pitr-verify-object-store.sh \
  /opt/lunchlineup/infrastructure/postgres/pitr-wal-provider-upload.sh \
  /opt/lunchlineup/tools/mc
CMD ["./backup.sh"]
