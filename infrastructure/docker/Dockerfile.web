# infrastructure/docker/Dockerfile.web
# Stage 1: Build
FROM node:22-alpine@sha256:16e22a550f3863206a3f701448c45f7912c6896a62de43add43bb9c86130c3e2 AS builder
WORKDIR /app

ARG NEXT_PUBLIC_API_URL=/api/v2
ARG INTERNAL_API_URL=http://api:3000/v1
ARG INTERNAL_API_V2_URL=http://api-v2:3002/v2
ARG NEXT_PUBLIC_OIDC_ENABLED=false
ARG NEXT_PUBLIC_SIGNUP_MODE=closed_beta
ARG NEXT_PUBLIC_TURNSTILE_SITE_KEY=
ARG NEXT_PUBLIC_PRIVACY_CONTACT_EMAIL=privacy@lunchlineup.example
ARG NEXT_PUBLIC_SUPPORT_CONTACT_EMAIL=support@lunchlineup.example
ARG NEXT_PUBLIC_DPA_CONTACT_EMAIL=privacy@lunchlineup.example
ARG NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
ARG NEXT_PUBLIC_APP_URL=http://localhost:3000
ARG NEXT_PUBLIC_APP_ENV=production

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    INTERNAL_API_URL=$INTERNAL_API_URL \
    INTERNAL_API_V2_URL=$INTERNAL_API_V2_URL \
    NEXT_PUBLIC_OIDC_ENABLED=$NEXT_PUBLIC_OIDC_ENABLED \
    NEXT_PUBLIC_SIGNUP_MODE=$NEXT_PUBLIC_SIGNUP_MODE \
    NEXT_PUBLIC_TURNSTILE_SITE_KEY=$NEXT_PUBLIC_TURNSTILE_SITE_KEY \
    NEXT_PUBLIC_PRIVACY_CONTACT_EMAIL=$NEXT_PUBLIC_PRIVACY_CONTACT_EMAIL \
    NEXT_PUBLIC_SUPPORT_CONTACT_EMAIL=$NEXT_PUBLIC_SUPPORT_CONTACT_EMAIL \
    NEXT_PUBLIC_DPA_CONTACT_EMAIL=$NEXT_PUBLIC_DPA_CONTACT_EMAIL \
    NEXT_PUBLIC_APP_ORIGIN=$NEXT_PUBLIC_APP_ORIGIN \
    NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL \
    NEXT_PUBLIC_APP_ENV=$NEXT_PUBLIC_APP_ENV

# Copy full monorepo (needed for workspace package resolution)
COPY . .

RUN npm ci --prefer-offline || npm ci

RUN npx turbo run build --filter=@lunchlineup/web

# Stage 2: Runtime
FROM node:22-alpine@sha256:16e22a550f3863206a3f701448c45f7912c6896a62de43add43bb9c86130c3e2 AS runner
WORKDIR /app

ARG NEXT_PUBLIC_API_URL=/api/v2
ARG INTERNAL_API_URL=http://api:3000/v1
ARG INTERNAL_API_V2_URL=http://api-v2:3002/v2
ARG NEXT_PUBLIC_OIDC_ENABLED=false
ARG NEXT_PUBLIC_SIGNUP_MODE=closed_beta
ARG NEXT_PUBLIC_TURNSTILE_SITE_KEY=
ARG NEXT_PUBLIC_PRIVACY_CONTACT_EMAIL=privacy@lunchlineup.example
ARG NEXT_PUBLIC_SUPPORT_CONTACT_EMAIL=support@lunchlineup.example
ARG NEXT_PUBLIC_DPA_CONTACT_EMAIL=privacy@lunchlineup.example
ARG NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
ARG NEXT_PUBLIC_APP_URL=http://localhost:3000
ARG NEXT_PUBLIC_APP_ENV=production

ENV NODE_ENV=production \
    HOME=/home/node \
    TMPDIR=/tmp \
    NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    INTERNAL_API_URL=$INTERNAL_API_URL \
    INTERNAL_API_V2_URL=$INTERNAL_API_V2_URL \
    NEXT_PUBLIC_OIDC_ENABLED=$NEXT_PUBLIC_OIDC_ENABLED \
    NEXT_PUBLIC_SIGNUP_MODE=$NEXT_PUBLIC_SIGNUP_MODE \
    NEXT_PUBLIC_TURNSTILE_SITE_KEY=$NEXT_PUBLIC_TURNSTILE_SITE_KEY \
    NEXT_PUBLIC_PRIVACY_CONTACT_EMAIL=$NEXT_PUBLIC_PRIVACY_CONTACT_EMAIL \
    NEXT_PUBLIC_SUPPORT_CONTACT_EMAIL=$NEXT_PUBLIC_SUPPORT_CONTACT_EMAIL \
    NEXT_PUBLIC_DPA_CONTACT_EMAIL=$NEXT_PUBLIC_DPA_CONTACT_EMAIL \
    NEXT_PUBLIC_APP_ORIGIN=$NEXT_PUBLIC_APP_ORIGIN \
    NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL \
    NEXT_PUBLIC_APP_ENV=$NEXT_PUBLIC_APP_ENV

# Copy Next.js build output and static assets
COPY --from=builder /app/apps/web/.next /app/.next
COPY --from=builder /app/apps/web/public /app/public
COPY --from=builder /app/apps/web/package.json /app/package.json

# Copy node_modules from builder to avoid workspace resolution issues
COPY --from=builder /app/node_modules /app/node_modules

RUN mkdir -p /app/.next/cache && chown node:node /app/.next/cache

USER node

EXPOSE 3000
CMD ["npm", "start"]
