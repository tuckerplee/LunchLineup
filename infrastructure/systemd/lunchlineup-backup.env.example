# Copy to /etc/lunchlineup/backup.env for static, non-secret scheduler settings.
# deploy-vm217-remote.sh atomically writes IMAGE_PREFIX, IMAGE_TAG,
# COMPOSE_SERVICE_ENV_FILE, and PRODUCTION_RUNTIME_ENV_SHA256 to the required
# /var/lib/lunchlineup/backup-release.env. Do not set a fallback runtime path here.

COMPOSE_PROJECT_NAME=lunchlineup
COMPOSE_IGNORE_ORPHANS=true
BACKUP_OFFSITE_CREDENTIALS_DIR=/etc/lunchlineup/backup-offsite
# The Compose backup job defaults to executing exact-object remote retention at 35 days.
BACKUP_OFFSITE_RETENTION_DAYS=35
BACKUP_OFFSITE_RETENTION_DRY_RUN=false
