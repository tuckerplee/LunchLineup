# Copy to /etc/lunchlineup/backup.env and edit the runtime env path if needed.
# deploy-vm217-remote.sh writes IMAGE_PREFIX and IMAGE_TAG to
# /var/lib/lunchlineup/backup-release.env after a successful production deploy.

COMPOSE_PROJECT_NAME=lunchlineup-production
COMPOSE_SERVICE_ENV_FILE=/opt/lunchlineup-secrets/runtime.env
COMPOSE_IGNORE_ORPHANS=true
BACKUP_OFFSITE_CREDENTIALS_DIR=/etc/lunchlineup/backup-offsite
# The Compose backup job defaults to executing exact-object remote retention at 35 days.
BACKUP_OFFSITE_RETENTION_DAYS=35
BACKUP_OFFSITE_RETENTION_DRY_RUN=false
