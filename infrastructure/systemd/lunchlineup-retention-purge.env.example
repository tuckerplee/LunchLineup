# Copy to /etc/lunchlineup/retention-purge.env and edit for production.
# The application-data unit pins execution; the retained-record review unit pins its dry-run and separate output paths.

RETENTION_PURGE_URL=https://lunchlineup.com/api/v2/admin/retention/purge-expired
RETENTION_PURGE_TOKEN_FILE=/run/secrets/retention_purge_token
RETENTION_PURGE_PROOF_FILE=/var/lib/lunchlineup/proofs/retention-purge-latest.json
RETENTION_PURGE_METRICS_FILE=/var/lib/node_exporter/textfile_collector/lunchlineup_retention_purge.prom
RETENTION_PURGE_LOCK_FILE=/run/lunchlineup/retention-purge.lock
RETENTION_PURGE_TIMEOUT_MS=30000
