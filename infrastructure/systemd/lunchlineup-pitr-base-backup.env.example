# Copy to /etc/lunchlineup/pitr-base-backup.env for static scheduler settings.
# The required /var/lib/lunchlineup/backup-release.env supplies the exact
# SHA/digest-bound COMPOSE_SERVICE_ENV_FILE and PRODUCTION_RUNTIME_ENV_SHA256.
# Do not set a fallback runtime path here.
COMPOSE_PROJECT_NAME=lunchlineup
COMPOSE_IGNORE_ORPHANS=true
